{
  "name": "update-server",
  "version": "1.0.0",
  "description": "listens for post requests and responds by following commands from a config file",
  "main": "update.js",
  "scripts": {
    "develop": "concurrently -c bgGreen -n 'typescript,node' 'npm run dev-build' 'npm run dev-run'",
    "dev-build": "npx tsc --watch --preserveWatchOutput",
    "dev-run": "node --watch --watch-preserve-output ./build/update.js -p 3000 -l updateServer",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "SuperDyl",
  "license": "ISC",
  "dependencies": {
    "express": "^4.19.2",
    "express-queue": "^0.0.13",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@tsconfig/recommended": "^1.0.13",
    "@types/express": "^5.0.6",
    "@types/yargs": "^17.0.35",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.2"
  }
}
